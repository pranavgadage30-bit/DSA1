#include <stdio.h>
#include <stdlib.h>
int main() {
  int *ptr;
  int ct = 0;
  int i;

  ptr = calloc(10, sizeof(int));
  for (i = 0; i < 10; i++) {
    printf("Enter any number: ");
    scanf("%d", ptr + i);
  }

  printf("\n----------------------------");
  for (i = 0; i < 10; i++) {
    printf("\n%d", *(ptr + i));
  }
  return 0;
}

