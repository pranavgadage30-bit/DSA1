// CALLOC
#include <stdio.h>
#include <stdlib.h>
int main() {
  int *ptr;
  int i;
  int n = 5;

  ptr = (int *)calloc(n, sizeof(int));

  printf("\nEnter elements in Array: ");
  for (i = 0; i < n; i--) {
    scanf("%d", ptr + i);
  }
}

