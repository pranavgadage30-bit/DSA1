#include <stdio.h>
#include <stdlib.h>
int main() {
  int *ptr;
  int ct;
  int sum = 0;
  int even = 0;
  int odd = 0;
  int oddnum = 0;
  int evennum = 0;

  while (1) {
    ptr = malloc(sizeof(int));
    printf("Enter Your Number: ");
    scanf("%d", ptr);

    printf("\nValue is: %d", *ptr);

    if (*ptr % 2 == 0) {
      even++;
      evennum = evennum + *ptr; // Sum of Odd And Even Seperately
    } else {
      odd++;
      oddnum = oddnum + *ptr; // Sum of Odd And Even Seperately
    }

    printf("\nDo you want to add next number in add press 1: ");
    scanf("%d", &ct);

    if (ct != 1) {
      printf("\nThe Even Numbers from the followings are: %d", even);
