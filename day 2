// Searching 
// 1. Linear Search 2. Binary Search 

// 1. Linear Search 
// Searches one by one 

#include<stdio.h>
int main(){
    int arr[]={1,2,3,4,5};
    int i;
    int flag = 1;

    int len = sizeof(arr)/sizeof(arr[0]);
    // Linear Search 
    int key ;
    printf("Enter Key: ");
    scanf("%d", &key);

    for(i=0;i<len;i++){
        if(arr[i]==key){
            flag = 0;
            printf("\nElement Found at %d !", i);
            break;
        }
    }
    if(flag=1){
        printf("Key not Found !!");
    }

}

// 2.Binary Search 
// finds arrays mid point and it requires array in sorted manner only !
// Divides by dividing arrays in  mid by mid 


// Binary is Better than Linear Search 
#include<stdio.h>
int main(){
    int arr[]={1,2,3,4,5};
    int flag = 0;

    int len = sizeof(arr)/sizeof(arr[0]);
    // Binary Search 
    int key;
    printf("Enter Key: ");
    scanf("%d", &key);

    int start=0, end = len-1, mid;

    while(start <= end){
        flag = 0;
        mid = (start+end)/2;
        if(arr[mid] == key){
            printf("Key found at %d index", mid);
            break;
        }
        else if(key <= arr[mid]){
            end = mid - 1;
        }
        else if(key >= arr[mid]){
            start = mid + 1;
        }
    }
    if(flag=1){
        printf("Key not Found ! ");
    }
}





